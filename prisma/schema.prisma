generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  nombre    String
  empresa   String?
  email     String?
  telefono  String
  mensaje   String
  createdAt DateTime @default(now())
}
